<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    tools:context=".SellActivity">

    <!-- Background Pattern Overlay (Subtle) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_african_pattern"
        android:scaleType="centerCrop"
        android:alpha="0.08"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <TextView
        android:id="@+id/tv_header_title"
        style="@style/TextAppearance.App.HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="List a Textbook"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="24dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_close"
        app:tint="?attr/colorOnSurface"
        android:contentDescription="Close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_header_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_header_title" />

    <!-- Image Upload Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_image_upload"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?android:attr/colorBackground"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_header_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_upload_preview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_add_photo"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="Add Photo" />

            <TextView
                android:id="@+id/tv_upload_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Upload Book Photos"
                style="@style/TextAppearance.App.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Form Fields -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_book_title"
        style="@style/Widget.App.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_image_upload">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_book_title"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Book Title" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_author_name"
        style="@style/Widget.App.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_book_title">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_author_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Author Name" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_isbn"
        style="@style/Widget.App.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_author_name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_isbn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="ISBN (Optional)" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_asking_price"
        style="@style/Widget.App.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_isbn">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_asking_price"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Asking Price (R)"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Condition Selection -->
    <TextView
        android:id="@+id/tv_condition_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Condition"
        style="@style/TextAppearance.App.TitleSmall"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_asking_price" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_condition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        app:selectionRequired="true"
        app:singleSelection="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_condition_label">

        <Button
            android:id="@+id/btn_condition_like_new"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Like New"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/btn_condition_good"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Good"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/btn_condition_fair"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Fair"
            app:cornerRadius="10dp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Publish Listing Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_publish_listing"
        style="@style/Widget.App.Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:text="Publish Listing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
